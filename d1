function autoMineOres()
	local oresFolder = workspace.__GAME_CONTENT.Ores
	while automationConfig.autoMineOres do
		if getgenv().AutoOpenBusy then
			task.wait(0.05)
			continue
		end
		local character = getCharacter()
		if not character then
			task.wait(1)
			continue
		end
		local mined = false
		for _, ore in ipairs(oresFolder:GetChildren()) do
			if not table.find(oresToMine, ore.Name) then continue end
			local function getOreHealthText()
				local ui = ore:FindFirstChild("OresTopUI")
				local bar = ui and ui:FindFirstChild("Bar")
				local lbl = bar and bar:FindFirstChild("Health")
				return lbl and lbl.Text
			end
			if getOreHealthText() == "Respawning..." then continue end
			character:PivotTo(ore:GetPivot() * CFrame.new(0, 1, 0))
			mined = true
			repeat
				task.wait(0.05)
			until getOreHealthText() == "Respawning..." or not automationConfig.autoMineOres or getgenv().AutoOpenBusy
			if not automationConfig.autoMineOres or getgenv().AutoOpenBusy then break end
		end
		if not mined then task.wait(0.5) end
	end
	if automationConfig.TpBackToBeforeMineOres and positionSavedBeforeMine then
		local character = getCharacter()
		if character then character:PivotTo(positionSavedBeforeMine) end
	end
end

function autoExchangeGems()
	while automationConfig.autoExchangeGems do
		if #gemsToExchange > 0 then
			for _, gem in ipairs(gemsToExchange) do
				if gem == "All" then
					RE_Main:FireServer("ExchangeAllMinerals")
					break
				end
				if _getCurrencyAmount(gem) and _getCurrencyAmount(gem) > 0 then
					RE_Main:FireServer("ExchangeMineral", gem)
				end
			end
		end
		task.wait(cooldowns.autoExchangeGems)
	end
end

function autoOpenCapsule()
	while automationConfig.autoOpenCapsule do
		local cType = capsuleConfig.capsuleType
		local cost = CAPSULE_COSTS[cType] or math.huge
		local zone = capsuleZones[cType]
		local char = getCharacter()

		if not Client then
			setCapsuleStatus("Brak Framework.Client — Nie można otworzyć.")
			task.wait(2)
			continue
		end
		if not (char and char:FindFirstChild("HumanoidRootPart")) then
			task.wait(0.5)
			continue
		end
		if not zone then
			setCapsuleStatus("Strefa nieustawiona! Użyj Capture Zone.")
			task.wait(2)
			continue
		end

		local prism = _getCurrencyAmount("Prism") or 0
		if capsuleConfig.checkPrism and prism < cost then
			task.wait(1)
			continue
		end

		if capsuleConfig.pauseMining then
			getgenv().AutoOpenBusy = true
			task.wait(0.1)
		end

		local minePos = char:GetPivot()
		char:PivotTo(CFrame.new(zone))
		task.wait(capsuleConfig.zoneWait)

		local before = _getCurrencyAmount("Prism") or 0
		pcall(function()
			Client.Fire("OpenCapsule", cType)
		end)
		task.wait(capsuleConfig.returnWait)
		local after = _getCurrencyAmount("Prism") or 0

		char:PivotTo(minePos)

		if capsuleConfig.pauseMining then
			getgenv().AutoOpenBusy = false
		end

		if after < before then
			setCapsuleStatus("Otwarto: " .. cType .. " (-" .. tostring(before - after) .. " Prism)")
		else
			setCapsuleStatus("Brak otwarcia. Zwiększ Zone Wait.")
		end

		task.wait(capsuleConfig.cycleCooldown)
	end
	getgenv().AutoOpenBusy = false
end

