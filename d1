	end
end

function autoMineOres()
	local oresFolder = workspace.__GAME_CONTENT:WaitForChild("Ores")
	while automationConfig.autoMineOres do
		if getgenv().AutoOpenBusy then task.wait(0.1) continue end
		local character = getCharacter()
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then task.wait(0.5) continue end
		
		local mined = false
		for _, ore in ipairs(oresFolder:GetChildren()) do
			if not oresToMine[ore.Name] then continue end
			
			local function getOreHealthText()
				local ui = ore:FindFirstChild("OresTopUI")
				local bar = ui and ui:FindFirstChild("Bar")
				local lbl = bar and bar:FindFirstChild("Health")
				return lbl and lbl.Text or ""
			end
			
			if string.find(getOreHealthText(), "Respawn") or getOreHealthText() == "" then continue end
			
			rootPart.CFrame = ore:GetPivot() * CFrame.new(0, 4, 0)
			mined = true
			
			local timeout = 0
			repeat
				task.wait(0.05)
				timeout = timeout + 0.05
			until string.find(getOreHealthText(), "Respawn") or not automationConfig.autoMineOres or getgenv().AutoOpenBusy or timeout > 5
			if not automationConfig.autoMineOres or getgenv().AutoOpenBusy then break end
		end
		if not mined then task.wait(0.2) end
	end
	if automationConfig.TpBackToBeforeMineOres and positionSavedBeforeMine then
		local character = getCharacter()
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if rootPart then rootPart.CFrame = positionSavedBeforeMine end
	end
end

function autoExchangeGems()
	while automationConfig.autoExchangeGems do
		local hasSelected = false
		if gemsToExchange["All"] then
			RE_Main:FireServer("ExchangeAllMinerals")
			hasSelected = true
		else
			for gemName, isSelected in pairs(gemsToExchange) do
				if isSelected and _getCurrencyAmount(gemName) and _getCurrencyAmount(gemName) > 0 then
					RE_Main:FireServer("ExchangeMineral", gemName)
					hasSelected = true
				end
			end
		end
		task.wait(hasSelected and cooldowns.autoExchangeGems or 1)
	end
end

function autoOpenCapsule()
	while automationConfig.autoOpenCapsule do
		local cType = capsuleConfig.capsuleType
		local cost = CAPSULE_COSTS[cType] or math.huge
		local zone = capsuleZones[cType]
		local char = getCharacter()

		if not Client or not (char and char:FindFirstChild("HumanoidRootPart")) or not zone then
			task.wait(1) continue
		end
		local prism = _getCurrencyAmount("Prism") or 0
		if capsuleConfig.checkPrism and prism < cost then task.wait(1) continue end

		if capsuleConfig.pauseMining then getgenv().AutoOpenBusy = true task.wait(0.1) end

		local minePos = char:GetPivot()
		char:PivotTo(CFrame.new(zone))
		task.wait(capsuleConfig.zoneWait)

		pcall(function() Client.Fire("OpenCapsule", cType) end)
		task.wait(capsuleConfig.returnWait)

		char:PivotTo(minePos)
		if capsuleConfig.pauseMining then getgenv().AutoOpenBusy = false end
		task.wait(capsuleConfig.cycleCooldown)
	end
	getgenv().AutoOpenBusy = false
end

