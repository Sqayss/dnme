-- ============================ HELPER FUNCTIONS ============================
local function _getCurrencyAmount(currency: string): number?
	local folder = currencies:FindFirstChild(currency)
	if not folder then return nil end
	local amountFolder = folder:FindFirstChild("Amount")
	if not amountFolder then return nil end
	local v = amountFolder:FindFirstChild("1")
	if not v then return nil end
	return tonumber(v.Value)
end

local function getCharacter()
	return localPlayer.Character
end

local function setCapsuleStatus(text)
	print("[Sqays Hub - Capsule] " .. text)
    OrionLib:MakeNotification({
        Name = "Capsule Status Update",
        Content = text,
        Image = "rbxassetid://4483345998",
        Time = 3
    })
end

-- ============================ AUTOMATION FUNCTIONS ============================
function gainFire()
	while automationConfig.gainFire do
		RE_Main:FireServer("GainFire")
		task.wait(cooldowns.gainFire)
	end
end

function rollRune()
	while automationConfig.rollRune do
		if #runesToRoll > 0 then
			for _, rune in ipairs(runesToRoll) do
				RE_Main:FireServer("RollRune", rune)
			end
		end
		task.wait(cooldowns.rollRune)
	end
end

function rollTier()
	while automationConfig.rollTier do
		RE_Main:FireServer("RollTier")
		task.wait(cooldowns.rollTier)
	end
end

function harvestWheat()
	while automationConfig.harvestWheat do
		local wheats = workspace.__GAME_CONTENT.Farm:GetChildren()
		for _, wheat in ipairs(wheats) do
			local cd = wheat:FindFirstChild("ClickDetector")
			if cd then pcall(fireclickdetector, cd) end
		end
		task.wait(cooldowns.harvestWheat)
	end
end

function autoDepositWheat()
	while automationConfig.autoWheatDeposet do
		RE_Main:FireServer("DepositWheat")
		local cd = tonumber(localPlayer.FEATURES.BREAD_CONVERTER._cooldown.Value) or 1
		task.wait(cd)
	end
end

function pumpWater()
	while automationConfig.pumpWater do
		RE_Main:FireServer("GainWater")
		task.wait(cooldowns.pumpWater)
	end
end

function convertWaterToIce()
	while automationConfig.convertWaterToIce do
		local selectedButton = automationConfig.IceButtonToConvert[1] or automationConfig.IceButtonToConvert
		if selectedButton then
			local cost = ICE_BUTTON_COSTS[tostring(selectedButton)]
			local water = _getCurrencyAmount("Water")
			local buttonNumber = tonumber(selectedButton)
			if water and cost and buttonNumber and water >= cost then
				RE_Main:FireServer("PressButton", buttonNumber)
			end
		end
		task.wait(cooldowns.convertWaterToIce)
	end
end

function hitTree()
	local isTreeSpawned = localPlayer.FEATURES.TREE.IsSpawned
	while automationConfig.hitTree do
		if tonumber(currentPrestige.Value) < 9 then
			warn("[Sqays Hub] Prestige level too low — disabling Tree Farm.")
			break
		end
		if isTreeSpawned.Value then
			RE_Main:FireServer("HitTree")
		end
		task.wait(cooldowns.hitTree)
	end
end

